{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://7hats.local/schemas/code-review-output.schema.json",
  "title": "7hats Code Review Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "skill",
    "mode",
    "review_scope",
    "verdict",
    "summary",
    "applied_standards",
    "scorecard",
    "metrics",
    "human_readable_report",
    "verified_facts",
    "assumptions",
    "findings",
    "open_questions",
    "testing_gaps",
    "residual_risks",
    "verification_steps",
    "missing_sources",
    "failed_gates"
  ],
  "properties": {
    "skill": {
      "const": "7hats-code-review"
    },
    "mode": {
      "type": "string",
      "enum": [
        "repo_aware",
        "fallback"
      ]
    },
    "review_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "targets"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "pull_request",
            "diff",
            "commit_range",
            "file_set",
            "repo_slice",
            "full_repo",
            "unknown"
          ]
        },
        "targets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "approved",
        "comment",
        "changes_requested",
        "needs_refinement"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "applied_standards": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source",
          "source_type",
          "strength",
          "categories",
          "notes"
        ],
        "properties": {
          "source": {
            "type": "string",
            "minLength": 1
          },
          "source_type": {
            "type": "string",
            "enum": [
              "target_repo",
              "fallback_bundle"
            ]
          },
          "strength": {
            "type": "string",
            "enum": [
              "explicit",
              "inferred"
            ]
          },
          "categories": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "correctness",
                "security",
                "contracts_data",
                "performance_reliability",
                "testing",
                "architecture",
                "maintainability",
                "readability"
              ]
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "scorecard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimensions",
        "overall_score",
        "review_confidence",
        "scoring_notes"
      ],
      "properties": {
        "dimensions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "dimension",
              "score",
              "weight",
              "evidence_count",
              "standard_refs",
              "confidence",
              "rationale"
            ],
            "properties": {
              "dimension": {
                "type": "string",
                "enum": [
                  "correctness",
                  "regression_risk",
                  "test_adequacy",
                  "security_privacy",
                  "contract_data_integrity",
                  "maintainability",
                  "standards_compliance"
                ]
              },
              "score": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 0,
                "maximum": 5
              },
              "weight": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100
              },
              "evidence_count": {
                "type": "integer",
                "minimum": 0
              },
              "standard_refs": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              },
              "rationale": {
                "type": "string",
                "minLength": 1
              },
              "cannot_score_reason": {
                "type": "string"
              }
            }
          }
        },
        "overall_score": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 5
        },
        "review_confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "scoring_notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blocking_findings_count",
        "non_blocking_findings_count",
        "findings_by_severity",
        "standards_coverage_percent",
        "evidence_coverage_percent"
      ],
      "properties": {
        "blocking_findings_count": {
          "type": "integer",
          "minimum": 0
        },
        "non_blocking_findings_count": {
          "type": "integer",
          "minimum": 0
        },
        "findings_by_severity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "critical",
            "high",
            "medium",
            "low"
          ],
          "properties": {
            "critical": {
              "type": "integer",
              "minimum": 0
            },
            "high": {
              "type": "integer",
              "minimum": 0
            },
            "medium": {
              "type": "integer",
              "minimum": 0
            },
            "low": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "standards_coverage_percent": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "evidence_coverage_percent": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "human_readable_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verdict_label",
        "executive_summary",
        "top_findings",
        "score_highlights",
        "next_actions"
      ],
      "properties": {
        "verdict_label": {
          "type": "string",
          "minLength": 1
        },
        "executive_summary": {
          "type": "string",
          "minLength": 1
        },
        "top_findings": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "score_highlights": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "next_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "verified_facts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "fact",
          "evidence"
        ],
        "properties": {
          "fact": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "category",
          "severity",
          "title",
          "file",
          "line",
          "why_it_matters",
          "evidence",
          "standards_sources"
        ],
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "correctness",
              "security",
              "contracts_data",
              "performance_reliability",
              "testing",
              "architecture",
              "maintainability",
              "readability"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "line": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "why_it_matters": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "standards_sources": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "suggested_fix": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          }
        }
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "testing_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "residual_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failed_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
