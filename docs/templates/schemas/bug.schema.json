{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "bug",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_type","title","business_context","technical_context","validation_context","execution_governance","source_references","readiness"],
  "properties": {
    "artifact_type": {"type":"string","const":"bug"},
    "title": {"type":"string","minLength":1},
    "business_context": {
      "type":"object","additionalProperties":false,
      "required":["user_business_impact","scope","out_of_scope"],
      "properties": {
        "user_business_impact": {"type":"string","minLength":1},
        "scope": {"type":"string","minLength":1},
        "out_of_scope": {"type":"string","minLength":1}
      }
    },
    "technical_context": {
      "type":"object","additionalProperties":false,
      "required":["environment","steps_to_reproduce","expected_result","actual_result","technical_risks"],
      "properties": {
        "environment": {"type":"string","minLength":1},
        "steps_to_reproduce": {"type":"array","minItems":1,"items":{"type":"string","minLength":1}},
        "expected_result": {"type":"string","minLength":1},
        "actual_result": {"type":"string","minLength":1},
        "technical_risks": {"type":"array","items":{"type":"string","minLength":1}}
      }
    },
    "validation_context": {
      "type":"object","additionalProperties":false,
      "required":["acceptance_criteria","qa_validation_path"],
      "properties": {
        "acceptance_criteria": {"type":"array","minItems":1,"items":{"type":"string","minLength":1}},
        "qa_validation_path": {"type":"string","minLength":1}
      }
    },
    "execution_governance": {
      "type":"object","additionalProperties":false,
      "required":["priority","severity","story_points","qa_evidence"],
      "properties": {
        "priority": {"type":"integer","minimum":1,"maximum":4},
        "severity": {"type":"string","enum":["Blocker","Critical","Major","Minor","Trivial"]},
        "story_points": {"type":"integer","minimum":1},
        "qa_evidence": {"type":"string","minLength":1}
      }
    },
    "source_references": {"type":"array","minItems":1,"items":{"type":"string","minLength":1}},
    "readiness": {"type":"object","additionalProperties":false,"required":["readiness_verdict"],"properties":{"readiness_verdict":{"type":"string","enum":["Ready","Needs Refinement"]},"failed_gates":{"type":"array","items":{"type":"string","minLength":1}},"missing_sources":{"type":"array","items":{"type":"string","minLength":1}}}}
  },
  "allOf": [{"if":{"properties":{"readiness":{"properties":{"readiness_verdict":{"const":"Needs Refinement"}},"required":["readiness_verdict"]}}},"then":{"properties":{"readiness":{"required":["failed_gates","missing_sources"]}}}}]
}