{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "epic",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_type","title","business_context","technical_context","validation_context","execution_governance","source_references","readiness"],
  "properties": {
    "artifact_type": {"type":"string","const":"epic"},
    "title": {"type":"string","minLength":1},
    "business_context": {"type":"object","additionalProperties":false,"required":["problem_opportunity_statement","business_outcome","target_users_segments","in_scope","out_of_scope"],"properties":{"problem_opportunity_statement":{"type":"string","minLength":1},"business_outcome":{"type":"string","minLength":1},"target_users_segments":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}},"in_scope":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}},"out_of_scope":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}}}},
    "technical_context": {
      "type":"object","additionalProperties":false,
      "required":["feasibility_summary","dependencies","technical_risks","milestones_story_breakdown_strategy"],
      "properties": {
        "feasibility_summary": {"type":"string","minLength":1},
        "dependencies": {"type":"array","items":{"type":"string","minLength":1}},
        "technical_risks": {"type":"array","items":{"type":"string","minLength":1}},
        "milestones_story_breakdown_strategy": {"type":"string","minLength":1}
      }
    },
    "validation_context": {"type":"object","additionalProperties":false,"required":["success_metrics","acceptance_validation_strategy","qa_validation_path"],"properties":{"success_metrics":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}},"acceptance_validation_strategy":{"type":"string","minLength":1},"qa_validation_path":{"type":"string","minLength":1}}},
    "execution_governance": {
      "type":"object","additionalProperties":false,
      "required":["priority","estimate_range_story_points","qa_evidence_strategy"],
      "properties": {
        "priority": {"type":"integer","minimum":1,"maximum":4},
        "estimate_range_story_points": {"type":"string","pattern":"^[0-9]+-[0-9]+$"},
        "qa_evidence_strategy": {"type":"string","minLength":1}
      }
    },
    "source_references": {"type":"array","minItems":1,"items":{"type":"string","minLength":1}},
    "readiness": {"type":"object","additionalProperties":false,"required":["readiness_verdict"],"properties":{"readiness_verdict":{"type":"string","enum":["Ready","Needs Refinement"]},"failed_gates":{"type":"array","items":{"type":"string","minLength":1}},"missing_sources":{"type":"array","items":{"type":"string","minLength":1}}}}
  },
  "allOf": [{"if":{"properties":{"readiness":{"properties":{"readiness_verdict":{"const":"Needs Refinement"}},"required":["readiness_verdict"]}}},"then":{"properties":{"readiness":{"required":["failed_gates","missing_sources"]}}}}]
}