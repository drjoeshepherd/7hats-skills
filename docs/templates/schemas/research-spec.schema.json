{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "research_spec",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_type","title","business_context","technical_context","validation_context","execution_governance","source_references","readiness"],
  "properties": {
    "artifact_type": {"type":"string","const":"research_spec"},
    "title": {"type":"string","minLength":1},
    "business_context": {"type":"object","additionalProperties":false,"required":["decision_to_inform","background_context","primary_uncertainty"],"properties":{"decision_to_inform":{"type":"string","minLength":1},"background_context":{"type":"string","minLength":1},"primary_uncertainty":{"type":"string","minLength":1}}},
    "technical_context": {"type":"object","additionalProperties":false,"required":["method","data_sources_instrumentation","execution_plan","limitations_bias_risks"],"properties":{"method":{"type":"string","minLength":1},"data_sources_instrumentation":{"type":"string","minLength":1},"execution_plan":{"type":"string","minLength":1},"limitations_bias_risks":{"type":"string","minLength":1}}},
    "validation_context": {"type":"object","additionalProperties":false,"required":["research_questions","hypothesis","metrics_decision_thresholds","decision_trigger"],"properties":{"research_questions":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}},"hypothesis":{"type":"string","minLength":1},"metrics_decision_thresholds":{"type":"string","minLength":1},"decision_trigger":{"type":"string","minLength":1}}},
    "execution_governance": {"type":"object","additionalProperties":false,"required":["priority","estimate_story_points_equivalent","qa_evidence"],"properties":{"priority":{"type":"integer","minimum":1,"maximum":4},"estimate_story_points_equivalent":{"type":"integer","minimum":1},"qa_evidence":{"type":"string","minLength":1}}},
    "source_references": {"type":"array","minItems":1,"items":{"type":"string","minLength":1}},
    "readiness": {"type":"object","additionalProperties":false,"required":["readiness_verdict"],"properties":{"readiness_verdict":{"type":"string","enum":["Ready","Needs Refinement"]},"failed_gates":{"type":"array","items":{"type":"string","minLength":1}},"missing_sources":{"type":"array","items":{"type":"string","minLength":1}}}}
  },
  "allOf": [{"if":{"properties":{"readiness":{"properties":{"readiness_verdict":{"const":"Needs Refinement"}},"required":["readiness_verdict"]}}},"then":{"properties":{"readiness":{"required":["failed_gates","missing_sources"]}}}}]
}