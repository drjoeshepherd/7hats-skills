{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "signal",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_type","title","business_context","technical_context","validation_context","execution_governance","source_references","readiness"],
  "properties": {
    "artifact_type": {"type":"string","const":"signal"},
    "title": {"type":"string","minLength":1},
    "business_context": {"type":"object","additionalProperties":false,"required":["problem_statement","why_now_urgency","desired_outcome"],"properties":{"problem_statement":{"type":"string","minLength":1,"maxLength":255},"why_now_urgency":{"type":"string","minLength":1},"desired_outcome":{"type":"string","minLength":1}}},
    "technical_context": {
      "type":"object","additionalProperties":false,
      "required":["feasibility_summary","dependencies_summary","technical_risk_summary","estimate_band"],
      "properties": {
        "feasibility_summary": {"type":"string","minLength":1},
        "dependencies_summary": {"type":"string","minLength":1},
        "technical_risk_summary": {"type":"string","minLength":1},
        "estimate_band": {"type":"string","enum":["XS","S","M","L","XL","XXL"]}
      }
    },
    "validation_context": {"type":"object","additionalProperties":false,"required":["success_metrics","acceptance_validation_approach","qa_validation_path"],"properties":{"success_metrics":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}},"acceptance_validation_approach":{"type":"string","minLength":1},"qa_validation_path":{"type":"string","minLength":1}}},
    "execution_governance": {"type":"object","additionalProperties":false,"required":["priority","estimate_story_points_equivalent","qa_evidence"],"properties":{"priority":{"type":"integer","minimum":1,"maximum":4},"estimate_story_points_equivalent":{"type":"integer","minimum":1},"qa_evidence":{"type":"string","minLength":1}}},
    "source_references": {"type":"array","minItems":1,"items":{"type":"string","minLength":1}},
    "readiness": {"type":"object","additionalProperties":false,"required":["readiness_verdict"],"properties":{"readiness_verdict":{"type":"string","enum":["Ready","Needs Refinement"]},"failed_gates":{"type":"array","items":{"type":"string","minLength":1}},"missing_sources":{"type":"array","items":{"type":"string","minLength":1}}}}
  },
  "allOf": [{"if":{"properties":{"readiness":{"properties":{"readiness_verdict":{"const":"Needs Refinement"}},"required":["readiness_verdict"]}}},"then":{"properties":{"readiness":{"required":["failed_gates","missing_sources"]}}}}]
}