{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "design_spec",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_type","title","business_context","technical_context","validation_context","execution_governance","source_references","readiness"],
  "properties": {
    "artifact_type": {"type":"string","const":"design_spec"},
    "title": {"type":"string","minLength":1},
    "business_context": {"type":"object","additionalProperties":false,"required":["requestor","problem_statement","desired_outcome","in_scope","out_of_scope"],"properties":{"requestor":{"type":"string","minLength":1},"problem_statement":{"type":"string","minLength":1},"desired_outcome":{"type":"string","minLength":1},"in_scope":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}},"out_of_scope":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}}}},
    "technical_context": {"type":"object","additionalProperties":false,"required":["dependencies","technical_constraints","primary_flow","edge_cases"],"properties":{"dependencies":{"type":"array","items":{"type":"string","minLength":1}},"technical_constraints":{"type":"array","items":{"type":"string","minLength":1}},"primary_flow":{"type":"string","minLength":1},"edge_cases":{"type":"array","items":{"type":"string","minLength":1}}}},
    "validation_context": {"type":"object","additionalProperties":false,"required":["success_criteria","design_validation_plan"],"properties":{"success_criteria":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}},"design_validation_plan":{"type":"string","minLength":1}}},
    "execution_governance": {"type":"object","additionalProperties":false,"required":["priority","estimate_story_points_equivalent","qa_evidence"],"properties":{"priority":{"type":"string","enum":["P0","P1","P2","P3"]},"estimate_story_points_equivalent":{"type":"integer","minimum":1},"qa_evidence":{"type":"string","minLength":1}}},
    "source_references": {"type":"array","minItems":1,"items":{"type":"string","minLength":1}},
    "readiness": {"type":"object","additionalProperties":false,"required":["readiness_verdict"],"properties":{"readiness_verdict":{"type":"string","enum":["Ready","Needs Refinement"]},"failed_gates":{"type":"array","items":{"type":"string","minLength":1}},"missing_sources":{"type":"array","items":{"type":"string","minLength":1}}}}
  },
  "allOf": [{"if":{"properties":{"readiness":{"properties":{"readiness_verdict":{"const":"Needs Refinement"}},"required":["readiness_verdict"]}}},"then":{"properties":{"readiness":{"required":["failed_gates","missing_sources"]}}}}]
}