{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "user_story",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_type","title","business_context","technical_context","validation_context","execution_governance","source_references","readiness"],
  "properties": {
    "artifact_type": {"type": "string", "const": "user_story"},
    "title": {"type": "string", "minLength": 1},
    "business_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["problem_statement","business_outcome","scope","out_of_scope"],
      "properties": {
        "problem_statement": {"type":"string","minLength":1},
        "business_outcome": {"type":"string","minLength":1},
        "scope": {"type":"string","minLength":1},
        "out_of_scope": {"type":"string","minLength":1},
        "assumptions": {"type":"array","items":{"type":"string","minLength":1}}
      }
    },
    "technical_context": {
      "type":"object",
      "additionalProperties": false,
      "required": ["implementation_approach","dependencies","technical_risks","size_assessment"],
      "properties": {
        "implementation_approach": {"type":"string","minLength":1},
        "dependencies": {"type":"array","items":{"type":"string","minLength":1}},
        "technical_risks": {"type":"array","items":{"type":"string","minLength":1}},
        "size_assessment": {"type":"string","enum":["XS","S","M","L","XL","XXL"]},
        "notes": {"type":"string"}
      }
    },
    "validation_context": {
      "type":"object",
      "additionalProperties": false,
      "required":["acceptance_criteria","qa_validation_path"],
      "properties": {
        "acceptance_criteria": {"type":"array","minItems":1,"items":{"type":"string","minLength":1}},
        "qa_validation_path": {"type":"string","minLength":1}
      }
    },
    "execution_governance": {
      "type":"object",
      "additionalProperties": false,
      "required":["priority","story_points","qa_evidence"],
      "properties": {
        "priority": {"type":"integer","minimum":1,"maximum":4},
        "story_points": {"type":"integer","minimum":1},
        "qa_evidence": {"type":"string","minLength":1}
      }
    },
    "source_references": {"type":"array","minItems":1,"items":{"type":"string","minLength":1}},
    "readiness": {
      "type":"object",
      "additionalProperties": false,
      "required":["readiness_verdict"],
      "properties": {
        "readiness_verdict": {"type":"string","enum":["Ready","Needs Refinement"]},
        "failed_gates": {"type":"array","items":{"type":"string","minLength":1}},
        "missing_sources": {"type":"array","items":{"type":"string","minLength":1}}
      }
    }
  },
  "allOf": [{"if":{"properties":{"readiness":{"properties":{"readiness_verdict":{"const":"Needs Refinement"}},"required":["readiness_verdict"]}}},"then":{"properties":{"readiness":{"required":["failed_gates","missing_sources"]}}}}]
}