{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "create_artifact.response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "readiness_verdict",
    "repo_mode",
    "grounding_status",
    "template_version",
    "contract_version"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "enum": [
        "mission",
        "signal",
        "epic",
        "user_story",
        "bug",
        "feature",
        "design_spec",
        "research_spec",
        "customer_request"
      ]
    },
    "content_markdown": {
      "type": "string"
    },
    "content_json": {
      "type": "object"
    },
    "readiness_verdict": {
      "type": "string",
      "enum": [
        "Ready",
        "Needs Refinement"
      ]
    },
    "repo_mode": {
      "type": "string",
      "enum": [
        "repo_aware",
        "generic"
      ]
    },
    "grounding_status": {
      "type": "string",
      "enum": [
        "grounded",
        "partial",
        "insufficient"
      ]
    },
    "failed_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_citations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source",
          "uri"
        ],
        "properties": {
          "source": {
            "type": "string",
            "minLength": 1
          },
          "uri": {
            "type": "string",
            "minLength": 1
          },
          "locator": {
            "type": "string",
            "minLength": 1
          },
          "evidence_type": {
            "type": "string",
            "enum": [
              "architecture_doc",
              "service_doc",
              "mapping_doc",
              "code_path",
              "ticket",
              "runbook",
              "other"
            ]
          },
          "confidence": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        }
      }
    },
    "orchestration_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intent",
        "micro_steps",
        "repo_mode",
        "required_outputs",
        "contribution_summary",
        "unresolved_risks",
        "receipt"
      ],
      "properties": {
        "intent": {
          "type": "string",
          "enum": [
            "clarify",
            "plan",
            "de-risk",
            "decide",
            "validate",
            "recover"
          ]
        },
        "micro_steps": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "repo_mode": {
          "type": "string",
          "enum": [
            "repo_aware",
            "generic"
          ]
        },
        "required_outputs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "contribution_summary": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "hat",
              "added"
            ],
            "properties": {
              "hat": {
                "type": "string",
                "enum": [
                  "product_owner",
                  "researcher",
                  "designer",
                  "engineer",
                  "marketer",
                  "entrepreneur",
                  "meta"
                ]
              },
              "added": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "unresolved_risks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "receipt": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "summary"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "complete",
                "partial"
              ]
            },
            "summary": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "reasoning_trace": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "intent_inference": {
          "type": "string",
          "minLength": 1
        },
        "constraint_classification": {
          "type": "string",
          "enum": [
            "ambiguity",
            "execution_planning",
            "risk_nfr",
            "option_conflict",
            "quality_gate_check",
            "delivery_drift"
          ]
        },
        "hat_selection_rationale": {
          "type": "string",
          "minLength": 1
        },
        "handoff_sequence": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "from_hat",
              "to_hat",
              "reason"
            ],
            "properties": {
              "from_hat": {
                "type": "string",
                "enum": [
                  "product_owner",
                  "researcher",
                  "designer",
                  "engineer",
                  "marketer",
                  "entrepreneur",
                  "meta"
                ]
              },
              "to_hat": {
                "type": "string",
                "enum": [
                  "product_owner",
                  "researcher",
                  "designer",
                  "engineer",
                  "marketer",
                  "entrepreneur",
                  "meta"
                ]
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "decision_points": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "tradeoffs_considered": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "final_merge_rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_best_action": {
      "type": "string",
      "minLength": 1
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 10
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "tool_version": {
      "type": "string",
      "minLength": 1
    },
    "template_version": {
      "type": "string",
      "minLength": 1
    },
    "contract_version": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "anyOf": [
        {
          "required": [
            "content_markdown"
          ]
        },
        {
          "required": [
            "content_json"
          ]
        }
      ]
    }
  ]
}
