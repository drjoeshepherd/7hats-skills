{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "route_hat.request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_text"
  ],
  "properties": {
    "request_text": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "mission",
        "signal",
        "epic",
        "user_story",
        "bug",
        "feature",
        "design_spec",
        "research_spec",
        "customer_request"
      ]
    },
    "context": {
      "type": "object"
    },
    "requested_alias": {
      "type": "string"
    }
  }
}
