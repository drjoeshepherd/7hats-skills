{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "route_hat.request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_text"
  ],
  "properties": {
    "request_text": {
      "type": "string",
      "minLength": 1
    },
    "intent": {
      "type": "string",
      "enum": [
        "clarify",
        "plan",
        "de-risk",
        "decide",
        "validate",
        "recover"
      ]
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "mission",
        "signal",
        "epic",
        "user_story",
        "bug",
        "feature",
        "design_spec",
        "research_spec",
        "customer_request"
      ]
    },
    "context": {
      "type": "object"
    },
    "repo_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "attached": {
          "type": "boolean"
        },
        "mode_hint": {
          "type": "string",
          "enum": [
            "repo_aware",
            "generic"
          ]
        },
        "source_refs": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "source",
                  "uri"
                ],
                "properties": {
                  "source": {
                    "type": "string",
                    "minLength": 1
                  },
                  "uri": {
                    "type": "string",
                    "minLength": 1
                  },
                  "locator": {
                    "type": "string",
                    "minLength": 1
                  },
                  "evidence_type": {
                    "type": "string",
                    "enum": [
                      "architecture_doc",
                      "service_doc",
                      "mapping_doc",
                      "code_path",
                      "ticket",
                      "runbook",
                      "other"
                    ]
                  },
                  "confidence": {
                    "type": "string",
                    "enum": [
                      "low",
                      "medium",
                      "high"
                    ]
                  }
                }
              }
            ]
          }
        }
      }
    },
    "requested_alias": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "repo_context": {
            "type": "object",
            "properties": {
              "mode_hint": {
                "const": "repo_aware"
              }
            },
            "required": [
              "mode_hint"
            ]
          }
        },
        "required": [
          "repo_context"
        ]
      },
      "then": {
        "properties": {
          "repo_context": {
            "type": "object",
            "required": [
              "source_refs"
            ],
            "properties": {
              "source_refs": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      }
    }
  ]
}
