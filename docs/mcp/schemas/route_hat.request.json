{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "route_hat.request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_text"
  ],
  "properties": {
    "request_text": {
      "type": "string",
      "minLength": 1
    },
    "intent": {
      "type": "string",
      "enum": [
        "clarify",
        "plan",
        "de-risk",
        "decide",
        "validate",
        "recover"
      ]
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "mission",
        "signal",
        "epic",
        "user_story",
        "bug",
        "feature",
        "design_spec",
        "research_spec",
        "customer_request"
      ]
    },
    "context": {
      "type": "object"
    },
    "repo_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "attached": {
          "type": "boolean"
        },
        "mode_hint": {
          "type": "string",
          "enum": [
            "repo_aware",
            "generic"
          ]
        },
        "source_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "requested_alias": {
      "type": "string"
    }
  }
}
