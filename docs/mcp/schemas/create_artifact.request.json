{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "create_artifact.request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "request_text",
    "output_format"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "enum": [
        "mission",
        "signal",
        "epic",
        "user_story",
        "bug",
        "feature",
        "design_spec",
        "research_spec",
        "customer_request"
      ]
    },
    "request_text": {
      "type": "string",
      "minLength": 1
    },
    "source_references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output_format": {
      "type": "string",
      "enum": [
        "markdown",
        "json"
      ]
    },
    "template_version": {
      "type": "string"
    },
    "alias": {
      "type": "string"
    }
  }
}
