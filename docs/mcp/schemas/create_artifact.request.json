{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "create_artifact.request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "request_text",
    "output_format"
  ],
  "properties": {
    "intent": {
      "type": "string",
      "enum": [
        "clarify",
        "plan",
        "de-risk",
        "decide",
        "validate",
        "recover"
      ]
    },
    "repo_mode": {
      "type": "string",
      "enum": [
        "repo_aware",
        "generic"
      ]
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "mission",
        "signal",
        "epic",
        "user_story",
        "bug",
        "feature",
        "design_spec",
        "research_spec",
        "customer_request"
      ]
    },
    "request_text": {
      "type": "string",
      "minLength": 1
    },
    "source_references": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source",
              "uri"
            ],
            "properties": {
              "source": {
                "type": "string",
                "minLength": 1
              },
              "uri": {
                "type": "string",
                "minLength": 1
              },
              "locator": {
                "type": "string",
                "minLength": 1
              },
              "evidence_type": {
                "type": "string",
                "enum": [
                  "architecture_doc",
                  "service_doc",
                  "mapping_doc",
                  "code_path",
                  "ticket",
                  "runbook",
                  "other"
                ]
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "low",
                  "medium",
                  "high"
                ]
              }
            }
          }
        ]
      }
    },
    "output_format": {
      "type": "string",
      "enum": [
        "markdown",
        "json"
      ]
    },
    "template_version": {
      "type": "string"
    },
    "alias": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "repo_mode": {
            "const": "repo_aware"
          }
        },
        "required": [
          "repo_mode"
        ]
      },
      "then": {
        "required": [
          "source_references"
        ],
        "properties": {
          "source_references": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "source",
                "uri"
              ],
              "properties": {
                "source": {
                  "type": "string",
                  "minLength": 1
                },
                "uri": {
                  "type": "string",
                  "minLength": 1
                },
                "locator": {
                  "type": "string",
                  "minLength": 1
                },
                "evidence_type": {
                  "type": "string",
                  "enum": [
                    "architecture_doc",
                    "service_doc",
                    "mapping_doc",
                    "code_path",
                    "ticket",
                    "runbook",
                    "other"
                  ]
                },
                "confidence": {
                  "type": "string",
                  "enum": [
                    "low",
                    "medium",
                    "high"
                  ]
                }
              }
            }
          }
        }
      }
    }
  ]
}
